<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Basic Sciences Quarterly — Q2 2026</title>
<style>
  

  :root {
    --ucd-blue: #002855;
    --ucd-gold: #DAAA00;
    --ucd-light-blue: #1B5299;
    --ucd-sky: #E8F0FE;
    --ucd-warm-gray: #F7F5F2;
    --ucd-dark: #30373D;
    --ucd-accent: #0073CF;
    --text-primary: #30373D;
    --text-secondary: #666059;
    --card-shadow: 0 2px 12px rgba(0,0,0,0.06);
    --card-hover: 0 8px 30px rgba(0,0,0,0.10);
    --warm-white: #FDFBF8;
    --warm-border: #DDD8D2;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #ffffff;
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── HERO ── */
  .hero {
    background: white;
    border-top: 4px solid var(--ucd-blue);
    border-bottom: 1px solid #eee;
    padding: 2.8rem 2.5rem 2.4rem;
    text-align: center;
  }
  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .hero-badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ucd-accent);
    margin-bottom: 0.9rem;
  }
  .hero h1 {
    font-family: 'Spectral', Georgia, serif;
    font-size: 4.3rem;
    font-weight: 600;
    color: var(--ucd-blue);
    line-height: 1.05;
    margin-bottom: 0;
  }
  .hero h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--ucd-blue);
    font-size: 1em;
  }
  .hero-rule {
    width: 60px;
    height: 2px;
    background: var(--ucd-gold);
    margin: 0.8rem auto;
  }
  .hero-subtitle {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 0.8rem;
  }
  .hero-meta {
    font-size: 0.72rem;
    color: #aaa;
    letter-spacing: 0.04em;
  }

  /* ── NAV BAR ── */
  .nav-bar {
    background: var(--ucd-warm-gray);
    border-bottom: 1px solid #e8e5e0;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    gap: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .nav-inner a {
    flex-shrink: 0;
    padding: 0.85rem 1.2rem;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-inner a:hover {
    color: var(--ucd-blue);
    border-bottom-color: var(--ucd-gold);
    background: rgba(0,40,85,0.03);
  }

  /* ── MAIN CONTENT ── */
  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem 3rem;
  }

  /* ── SECTION HEADERS ── */
  .section-header {
    margin: 3rem 0 1.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--warm-border);
  }
  .section-header:first-child { border-top: none; padding-top: 2.5rem; }
  .section-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ucd-accent);
    margin-bottom: 0.4rem;
  }
  .section-header h2 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--ucd-blue);
    line-height: 1.2;
  }
  .section-header p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    margin-top: 0.4rem;
    line-height: 1.6;
  }

  /* ── DEPARTMENT COLORS (matches publication list) ── */
  /* Physiology  → crimson  #C62828  */
  /* Pharmacology → indigo  #4527A0  */
  /* Public Health Sciences → orange-300 #FDBA74  */
  /* Biochemistry → amber   #E65100  */
  /* MMI          → teal    #00695C  */

  /* ── BLUE RIDGE RANKINGS ── */
  .ranking-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1rem;
    margin: 1.2rem 0;
  }
  .rank-card {
    background: var(--warm-white);
    border: 1px solid var(--warm-border);
    border-radius: 14px;
    padding: 1.2rem 0.9rem 1rem;
    text-align: center;
    transition: box-shadow 0.25s, transform 0.25s;
    border-bottom: 4px solid #ccc;
  }
  .rank-card:hover {
    box-shadow: var(--card-hover);
    transform: translateY(-2px);
  }

  /* dept bottom-border colors */
  .rank-card.dept-physio  { border-bottom-color: #C62828; }
  .rank-card.dept-pharma  { border-bottom-color: #4527A0; }
  .rank-card.dept-cellbio { border-bottom-color: #00695C; }
  .rank-card.dept-biochem { border-bottom-color: #1565C0; }
  .rank-card.dept-mmi     { border-bottom-color: #E65100; }
  .rank-card.dept-phs     { border-bottom-color: #FDBA74; }

  /* dept color on bottom border only — text stays neutral */
  .rank-card .dept-name { color: var(--text-primary); }
  .rank-card .stat-num  { color: var(--text-primary); }

  .rank-card .dept-name {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.35;
    margin-bottom: 1rem;
    height: 3.8em;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-card .rank-stats {
    display: flex;
  }
  .rank-card .rank-stat {
    flex: 1;
    padding: 0.35rem 0.25rem;
  }
  .rank-card .rank-stat + .rank-stat {
    border-left: 1px solid #f0f0f0;
  }
  .rank-card .stat-num {
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.22rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: nowrap;
    white-space: nowrap;
    gap: 0.2em;
  }
  .rank-card .rank-num { font-size: 1.6rem; }
  .rank-card .fund-num { font-size: 1.4rem; }
  .rank-card .stat-num .of {
    font-size: 0.65rem;
    font-weight: 500;
    opacity: 0.5;
  }
  .rank-card .stat-lbl {
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #aaa;
  }

  /* ── RANKING TABLE ── */
  .ranking-table-wrap {
    margin: 1.2rem 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--warm-border);
  }
  .ranking-table-title {
    background: var(--ucd-blue);
    color: white;
    padding: 0.8rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .dept-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.4rem 0 0;
    cursor: pointer;
    user-select: none;
    padding: 0.35rem 0;
  }
  .dept-bar:hover .dept-label { color: #1B3F5E; }
  .dept-label {
    color: var(--ucd-blue);
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .dept-rule {
    flex: 1;
    height: 1px;
    background: #ddd;
  }
  .dept-toggle-arrow {
    font-size: 0.65rem;
    color: var(--ucd-blue);
    flex-shrink: 0;
    transition: transform 0.2s;
    display: inline-block;
  }
  .dept-toggle-arrow.open { transform: rotate(90deg); }
  .dept-body { margin-top: 0.5rem; display: none; }
  table.ranking-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  table.ranking-table th {
    background: var(--ucd-warm-gray);
    text-align: left;
    padding: 0.65rem 1rem;
    font-weight: 600;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--warm-border);
  }
  table.ranking-table td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #EDE8E2;
    background: var(--warm-white);
  }
  table.ranking-table tr:last-child td { border-bottom: none; }
  table.ranking-table tr.highlight {
    background: linear-gradient(90deg, #FFF9E6, #FFFDF5);
    font-weight: 600;
  }
  table.ranking-table tr.highlight td:first-child {
    border-left: 3px solid var(--ucd-gold);
  }
  table.ranking-table .funding-col {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* ── CONTENT CARDS ── */
  .card-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin: 1.2rem 0;
  }
  .card {
    background: white;
    border: 1px solid var(--warm-border);
    border-radius: 2px;
    padding: 1.2rem 1.4rem;
    transition: box-shadow 0.2s;
  }
  .card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
  .card-tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    line-height: 1;
    height: 1.6rem;
    margin-bottom: 0;
  }
  .tag-paper { background: #E8F0FE; color: #1B5299; }
  .tag-award { background: #FFF3CD; color: #856404; }
  .tag-grant { background: #D4EDDA; color: #155724; }
  .tag-recruit { background: #F0E6FF; color: #5B21B6; }
  .tag-news { background: #FFE8E8; color: #C0392B; }
  .tag-interview { background: #E3F2FD; color: #0D47A1; }
  .tag-op-ed { background: #F3E5F5; color: #6A1B9A; }

  /* ── DEPARTMENT BADGE (for paper cards) ── */
  .card-dept-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    line-height: 1;
    height: 1.6rem;
    margin-left: 0;
    margin-bottom: 0;
  }
  .card-dept-badge.dept-biochem { background: rgba(138, 178, 223, 0.5); color: #1B5299; }
  .card-dept-badge.dept-cellbio { background: rgba(127, 180, 173, 0.5); color: #2D5450; }
  .card-dept-badge.dept-pharmacology { background: rgba(162, 147, 207, 0.5); color: #3E2C6B; }
  .card-dept-badge.dept-physiology { background: rgba(226, 147, 147, 0.5); color: #7B1515; }
  .card-dept-badge.dept-mmi { background: rgba(242, 168, 127, 0.5); color: #6B3410; }
  .card-dept-badge.dept-phs { background: rgba(254, 220, 185, 0.5); color: #7C2D12; }
  .card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    color: var(--ucd-dark);
  }
  .card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }
  .card .card-meta {
    font-size: 0.75rem;
    color: #999;
    margin-top: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .publication-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .btn-paper {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  .btn-paper:hover { transform: translateY(-1px); }
  .btn-doi {
    background: var(--ucd-blue);
    color: white;
  }
  .btn-doi:hover { background: #1B5299; }
  .btn-pubmed {
    background: #F0F4F8;
    color: #555;
    border: 1px solid #D0D8E4;
  }
  .btn-pubmed:hover { background: #E3EBF4; }

  /* ── PLACEHOLDER ── */
  .placeholder {
    background: #FAFAF8;
    border: 2px dashed #ddd;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    color: #aaa;
    font-size: 0.85rem;
    margin: 0.8rem 0;
  }
  .placeholder strong { color: #888; }

  /* ── NUMBERS ROW ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--ucd-sky);
    border-radius: 12px;
  }
  .stat-item { text-align: center; }
  .stat-item .stat-num {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--ucd-blue);
    line-height: 1.1;
  }
  .stat-item .stat-label {
    font-size: 0.72rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.2rem;
  }

  /* ── FOOTER ── */
  .footer {
    background: var(--ucd-blue);
    color: rgba(255,255,255,0.7);
    padding: 2rem;
    text-align: center;
    font-size: 0.8rem;
  }
  .footer strong { color: white; }
  .footer a { color: var(--ucd-gold); text-decoration: none; }

  /* ── WELCOME ── */
  .welcome {
    background: var(--ucd-warm-gray);
    border-radius: 12px;
    padding: 1.5rem 1.8rem;
    margin: 2rem 0 0;
    border-left: 4px solid var(--ucd-gold);
  }
  .welcome p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .welcome .sig {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--ucd-blue);
    font-size: 0.85rem;
  }
  .welcome .sig-title {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--text-secondary);
  }

  /* ── GENENTECH-STYLE SECTION CARDS ── */
  .gene-grid {
    display: grid;
    gap: 1rem;
    margin: 2rem 0;
    align-items: stretch;
  }
  .gene-card {
    background: white;
    border: 1px solid var(--warm-border);
    border-radius: 2px;
    overflow: hidden;
    transition: box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .gene-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.10); }
  .gene-card-media {
    width: 100%;
    height: 180px;
    overflow: hidden;
    flex-shrink: 0;
    background: #ddd;
  }
  .gene-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .gene-card:hover .gene-card-media img { transform: scale(1.03); }
  .gene-card-body {
    padding: 1.1rem 1.2rem 1.4rem;
    flex: 1;
  }
  .gene-card-body h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ucd-dark);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .gene-card-body p {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.58;
  }

  /* ── HERO PANEL GRID (Q1 spans 2 rows, 6 panels in 3×2) ── */
  .gene-grid-hero {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
    margin: 2rem 0;
    align-items: stretch;
  }
  .gene-card-highlight {
    grid-row: span 2;
    display: grid;
    grid-template-rows: subgrid;
    overflow: visible;
  }
  .gene-card-highlight .gene-card-media-tall {
    min-height: 0;
    height: auto;
  }
  .gene-card-highlight .gene-card-body {
    /* sits in row 2 — subgrid aligns it with adjacent row 2 cards */
  }

  /* ── PERIOD BAR (expandable section header) ── */
  .period-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 2.5rem 0 0;
    cursor: pointer;
    user-select: none;
  }
  .period-bar:hover .period-pill { background: #1B3F5E; }
  .period-pill {
    background: var(--ucd-blue);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 0.9rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .period-arrow {
    font-size: 0.65rem;
    color: #aaa;
    flex-shrink: 0;
    transition: transform 0.2s;
    display: inline-block;
  }
  .period-arrow.open { transform: rotate(90deg); }
  .period-rule {
    flex: 1;
    height: 1px;
    background: #ddd;
  }
  .period-count {
    font-size: 0.75rem;
    color: #aaa;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .period-body { margin-top: 1rem; }

  /* ── ACTION PANELS ── */
  .gene-card-action { cursor: pointer; }
  .toggle-arrow {
    font-size: 0.75rem;
    color: var(--ucd-accent);
    transition: transform 0.2s;
    display: inline-block;
  }
  .toggle-arrow.open { transform: rotate(180deg); }

  /* ── RESPONSIVE ── */
  @media (max-width: 800px) {
    .gene-grid-hero { grid-template-columns: repeat(2, 1fr); }
    .gene-card-highlight { grid-row: span 1; }
    .gene-card-highlight .gene-card-media-tall { min-height: 160px; }
  }
  @media (max-width: 700px) {
    .gene-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .hero { padding: 2rem 1.2rem 1.5rem; }
    .content { padding: 0 1.2rem 2rem; }
    .nav-inner a { padding: 0.7rem 0.9rem; font-size: 0.75rem; }
    .ranking-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .gene-grid { grid-template-columns: 1fr; }
    .gene-grid-hero { grid-template-columns: 1fr; }
    .gene-card-highlight { grid-row: span 1; }
  }
</style>
</head>
<body style='font-family:"Inter", -apple-system, BlinkMacSystemFont, sans-serif; background:#fff; color:var(--text-primary); line-height:1.6; -webkit-font-smoothing:antialiased'>

<!-- ════════════════════ HERO ════════════════════ -->
<div class="hero" style="background:white; border-top:4px solid var(--ucd-blue); border-bottom:1px solid #eee; padding:2.8rem 2.5rem 2.4rem; text-align:center" align="center">
  <div class="hero-inner" style="max-width:900px; margin:0 auto">
    <div class="hero-badge" style="font-size:0.62rem; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--ucd-accent); margin-bottom:0.9rem">UC Davis School of Medicine  ·  Basic Sciences</div>
    <h1 style='font-family:"Spectral", Georgia, serif; font-size:4.3rem; font-weight:600; color:var(--ucd-blue); line-height:1.05; margin-bottom:0'>Basic Sciences <em style="font-style:italic; font-weight:300; color:var(--ucd-blue); font-size:1em">Quarterly</em>
</h1>
    <div class="hero-rule" style="width:60px; height:2px; background:var(--ucd-gold); margin:0.8rem auto" width="60" height="2"></div>
    <div class="hero-subtitle" style="font-size:0.88rem; color:var(--text-secondary); margin-bottom:0.8rem">Research, Rankings &amp; Recognition from UC Davis School of Medicine</div>
    <div class="hero-meta" style="font-size:0.72rem; color:#aaa; letter-spacing:0.04em">Q2 2026  ·  April – June  ·  Office of the Vice Dean for Basic Sciences</div>
  </div>
</div>

<!-- ════════════════════ NAV ════════════════════ -->
<div class="nav-bar" style="background:var(--ucd-warm-gray); border-bottom:1px solid #e8e5e0; padding:0; position:sticky; top:0; z-index:100">
  <div class="nav-inner" style="max-width:900px; margin:0 auto; display:flex; gap:0; overflow-x:auto; -webkit-overflow-scrolling:touch">
