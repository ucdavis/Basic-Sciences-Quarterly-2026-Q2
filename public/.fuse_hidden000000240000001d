  el.style.display = open ? 'none' : 'block';
  if (arrow) arrow.classList.toggle('open', !open);
  if (!open) {
    setTimeout(function(){ el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 50);
  }
}
function togglePeriod(bodyId, arrowId) {
